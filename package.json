{
  "name": "torch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun ./scripts/vite-cli.ts dev",
    "build": "bun ./scripts/vite-cli.ts build",
    "preview": "bun ./scripts/vite-cli.ts preview",
    "typecheck": "tsc --noEmit",
    "postinstall": "sh postinstall.sh",
    "pipeline": "bun ./pipeline/cli.ts",
    "pipeline:discover": "bun ./pipeline/cli.ts discover",
    "pipeline:scrape": "bun ./pipeline/cli.ts scrape",
    "pipeline:build-db": "bun ./pipeline/cli.ts build",
    "pipeline:stats": "bun ./pipeline/cli.ts stats",
    "pipeline:validate": "bun ./pipeline/cli.ts validate",
    "pipeline:search": "bun ./pipeline/cli.ts search",
    "pipeline:check-dupes": "bun ./pipeline/cli.ts check-dupes",
    "pipeline:verify-all": "bun ./pipeline/cli.ts verify-all"
  },
  "devDependencies": {
    "@rollup/rollup-android-arm64": "4.59.0",
    "@rollup/wasm-node": "4.59.0",
    "@tailwindcss/vite": "4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "1.2.0"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "type": "module"
